# Resonance Engine — Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://resonance:resonance@localhost:5432/resonance
REDIS_URL=redis://localhost:6379/0

# SEC EDGAR
EDGAR_USER_AGENT=Resonance Engine team@resonance-engine.com

# Vector Store (Phase 1)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=resonance-events
PINECONE_ENVIRONMENT=

# Embeddings (Phase 1)
OPENAI_API_KEY=

# Market Data (Phase 1)
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# News (Phase 2)
NEWSAPI_KEY=
GDELT_BASE_URL=https://api.gdeltproject.org/api/v2

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
